static_resources:
  listeners:
    - name: http_listener
      address:
        socket_address:
          address: 0.0.0.0
          port_value: 8099
      filter_chains:
        - filters:
            - name: envoy.filters.network.http_connection_manager
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                codec_type: auto
                stat_prefix: ingress_http

                route_config:
                  name: local_route
                  virtual_hosts:
                    - name: backend
                      domains: ["*"]

                      cors:
                        allow_origin_string_match:
                          - safe_regex:
                              google_re2: {}
                              regex: ".*"
                        allow_methods: "GET, POST, PUT, DELETE, OPTIONS"
                        allow_headers: "*"
                        expose_headers: "*"
                        max_age: "86400"
                        allow_credentials: false

                      routes:
                        # =========================
                        # BROKER PUBLIC (NO AUTH)  <-- moved to top
                        # =========================

                        # =========================
                        # PRE-FLIGHT (NO AUTH)
                        # =========================
                        - match:
                            prefix: "/"
                            headers:
                              - name: ":method"
                                exact_match: "OPTIONS"
                          direct_response:
                            status: 200
                          typed_per_filter_config:
                            envoy.filters.http.ext_authz:
                              "@type": type.googleapis.com/envoy.extensions.filters.http.ext_authz.v3.ExtAuthzPerRoute
                              disabled: true
                          response_headers_to_add:
                            - header:
                                key: Access-Control-Allow-Origin
                                value: "*"
                            - header:
                                key: Access-Control-Allow-Methods
                                value: "GET, POST, PUT, DELETE, OPTIONS"
                            - header:
                                key: Access-Control-Allow-Headers
                                value: "*"
                            - header:
                                key: Access-Control-Max-Age
                                value: "86400"

                        # =========================
                        # API ROUTES
                        # =========================
                        - match:
                            prefix: "/api/v2/auth"
                          route:
                            cluster: auth
                            prefix_rewrite: "/api/v2"

                        - match:
                            prefix: "/api/v2/amm"
                          route:
                            cluster: amm
                            prefix_rewrite: "/api/v2"

                        - match:
                            prefix: "/api/v2/broker"
                          route:
                            cluster: broker
                            prefix_rewrite: "/api/v2"

                        - match:
                            prefix: "/api/v2/trade"
                          route:
                            cluster: api
                            prefix_rewrite: "/api/v2"

                        - match:
                            prefix: "/api/v2/applogic"
                          route:
                            cluster: applogic
                            prefix_rewrite: "/api"

                        - match:
                            prefix: "/api/v2/finex"
                          route:
                            cluster: spot
                            prefix_rewrite: "/api/v2"

                        - match:
                            prefix: "/api/v2/stock"
                          route:
                            cluster: stock
                            prefix_rewrite: "/api/v2"

                        # =========================
                        # WEBSOCKETS
                        # =========================
                        - match:
                            prefix: "/api/v2/websocket/public"
                          route:
                            cluster: socket
                            prefix_rewrite: "/"
                            upgrade_configs:
                              - upgrade_type: websocket

                        - match:
                            prefix: "/api/v2/websocket/private"
                          route:
                            cluster: socket
                            prefix_rewrite: "/"
                            upgrade_configs:
                              - upgrade_type: websocket

                http_filters:
                  - name: envoy.filters.http.cors
                    typed_config: {}

                  - name: envoy.filters.http.ext_authz
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.ext_authz.v3.ExtAuthz
                      http_service:
                        server_uri:
                          uri: http://auth:8001
                          cluster: auth
                          timeout: 1s
                        path_prefix: "/api/v2/auth"
                        authorization_request:
                          allowed_headers:
                            patterns:
                              - exact: cookie
                              - exact: x-auth-apikey
                              - exact: x-auth-nonce
                              - exact: x-auth-signature
                              - exact: user-agent
                              - exact: x-forwarded-host
                              - exact: x-forwarded-for
                              - exact: x-forwarded-proto
                        authorization_response:
                          allowed_upstream_headers:
                            patterns:
                              - exact: authorization
                          allowed_client_headers:
                            patterns:
                              - exact: set-cookie
                              - exact: www-authenticate
                              - exact: location

                  - name: envoy.filters.http.router
                    typed_config: {}

      per_connection_buffer_limit_bytes: 10000000

  clusters:
    - name: auth
      connect_timeout: 0.25s
      type: strict_dns
      lb_policy: round_robin
      load_assignment:
        cluster_name: auth
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: auth
                      port_value: 8001

    - name: amm
      connect_timeout: 0.25s
      type: strict_dns
      lb_policy: round_robin
      load_assignment:
        cluster_name: amm
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: amm
                      port_value: 6000

    - name: broker
      connect_timeout: 0.25s
      type: strict_dns
      lb_policy: round_robin
      load_assignment:
        cluster_name: broker
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: broker
                      port_value: 2022

    - name: api
      connect_timeout: 0.25s
      type: strict_dns
      lb_policy: round_robin
      load_assignment:
        cluster_name: api
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: api
                      port_value: 8000

    - name: applogic
      connect_timeout: 0.25s
      type: strict_dns
      lb_policy: round_robin
      load_assignment:
        cluster_name: applogic
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: applogic
                      port_value: 3000

    - name: spot
      connect_timeout: 0.25s
      type: strict_dns
      lb_policy: round_robin
      load_assignment:
        cluster_name: spot
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: spot
                      port_value: 3000

    - name: stock
      connect_timeout: 0.25s
      type: strict_dns
      lb_policy: round_robin
      load_assignment:
        cluster_name: stock
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: stock
                      port_value: 3000

    - name: socket
      connect_timeout: 0.25s
      type: strict_dns
      lb_policy: round_robin
      load_assignment:
        cluster_name: socket
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: socket
                      port_value: 8080

admin:
  access_log_path: /dev/null
  address:
    socket_address:
      address: 0.0.0.0
      port_value: 9099
