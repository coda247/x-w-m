ENV=development
PORT=8080
DB_HOST=<%= @config['database']['host'] %>
DB_PORT=<%= @config['database']['port'] %>
DB_USER=<%= @config['database']['user'] %>
DB_PASSWORD=<%= @config['database']['password'] %>
DB_NAME=api_production
DB_SSLMODE=disable
CLOUDFLARE_API_TOKEN=<%= @config['dns']['cloudflare_api_token'] %>
CLOUDFLARE_ZONE_ID=<%= @config['dns']['cloudflare_zone_id'] %>
PARENT_DOMAIN=<%= @config['dns']['parent_domain'] %>
ORIGIN_HOSTNAME=<%= @config['dns']['origin_hostname'] %>
KAFKA_BROKER=kafka:9092

