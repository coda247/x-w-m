services:
  traefik:
    image: traefik
    restart: always
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ../config/traefik/dyn.yml:/etc/traefik/dyn.yml:ro
      - ../config/traefik/config.yml:/etc/traefik/traefik.yml:ro
      - /etc/letsencrypt/live/www.cubegroup.io/fullchain.pem:/etc/traefik/certs/fullchain.pem:ro
      - /etc/letsencrypt/live/www.cubegroup.io/privkey.pem:/etc/traefik/certs/privkey.pem:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.cubegroup.rule=Host(`www.cubegroup.io`)"
      <%- if @config['ssl']['enabled'] -%>
      - "traefik.http.routers.cubegroup.entrypoints=websecure"
      - "traefik.http.routers.cubegroup.tls=true"
      <%- else -%>
      - "traefik.http.routers.cubegroup.entrypoints=web"
      <%- end -%>
